# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp / Meta Cloud API ──────────────────────────────
# Token permanente (System User Token) de Meta for Developers
WHATSAPP_TOKEN=EAAxxxxx...

# ID del número de teléfono (no el número real, el ID de Meta)
# Lo encontrás en developers.facebook.com → tu app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# App Secret para verificar la firma HMAC de los webhooks
# Lo encontrás en tu app → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=abc123def456...

# Token que vos elegís para verificar el webhook al configurarlo en Meta
# Puede ser cualquier string; usá el mismo cuando configures el webhook en Meta
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_seguro

# ── Google Sheets ──────────────────────────────────────────
# Ruta al JSON del Service Account de Google Cloud
GOOGLE_CREDENTIALS_FILE=credentials.json
